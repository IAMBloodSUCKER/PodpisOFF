# PodpisOFF / SubOFF — local development
# Copy to .env and adjust

POSTGRES_DB=podpisoff
POSTGRES_USER=podpisoff
POSTGRES_PASSWORD=podpisoff
POSTGRES_PORT=5433

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Default locale: ru (ПодписOFF) | en (SubOFF)
DEFAULT_LOCALE=ru

# Email (optional for MVP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=reminders@localhost

# ЮKassa (production only)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Admin bootstrap (first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
