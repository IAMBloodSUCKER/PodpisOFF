# PodpisOFF / SubOFF — local development
# Copy to .env and adjust

POSTGRES_DB=podpisoff
POSTGRES_USER=podpisoff
POSTGRES_PASSWORD=podpisoff
POSTGRES_PORT=5433

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Default locale: ru (ПодписOFF) | en (SubOFF)
DEFAULT_LOCALE=ru

# Email (optional)
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=reminders@localhost

# Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=PodpisOFF_bot
TELEGRAM_WEBHOOK_SECRET=
# Public backend URL for webhook registration, e.g. https://api.podpisoff.app
TELEGRAM_WEBHOOK_PUBLIC_URL=

# ЮKassa (production only)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Admin bootstrap (first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_PANEL_KEY=podpisoff-admin-dev-key
